{
  "regions": ["icn1"],
  "crons": [
    {
      "path": "/api/admin/stats/aggregate",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/event-reeval",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/order-autocomplete",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/event-bean-reward",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/campaign-grant-all",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/bean-balance-check",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/fbck-pi-payout",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/tip-pi-payout",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/refund-sweep",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/chat-noti",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/metric-purge",
      "schedule": "30 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(self), geolocation=(self)"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" },
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}
