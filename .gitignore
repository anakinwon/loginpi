# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
.playwright-mcp/

# Claude Code 내부 설정 — skills/agents/hooks/settings.json은 커밋 (파일럿 정책)
.claude/*
!.claude/skills/
!.claude/skills/**
!.claude/agents/
!.claude/agents/**
!.claude/hooks/
!.claude/hooks/**
!.claude/workflows/
!.claude/workflows/**
!.claude/settings.json

# 스크린샷 (개발용)
*.png
*.jpg
*.jpeg

# public 폴더 정적 이미지는 배포에 필요하므로 예외 처리
!public/*.png
!public/*.jpg
!public/*.jpeg
!public/*.svg
!public/*.ico
package-lock.json

# pptx 빌드 작업 폴더 (build.js는 커밋, 의존성·임시 unzip 폴더는 제외)
docs/.pptx-build/node_modules/
docs/.pptx-build/qa*/

# 백서 PDF 빌드 중간 HTML(재생성 가능, build.js·PDF만 커밋)
.whitepaper-build/*.html

# 환경변수 템플릿은 추적(실값 없는 placeholder만). 실값 파일(.env.local 등)은 위 .env* 규칙으로 제외 유지
!.env.example

# 운영DB 초기화 번들(파생물·505KB, scripts/build-prod-db-bundle.mjs로 재생성)
sql/_prod_db_bundle.sql

# 운영DB 부트스트랩 일회성 산출물(실데이터 — 커밋 금지)
prod_schema.sql
prod_seed*.sql

# MS Office 임시 잠금 파일
~$*
**/~$*

# 세션 임시 검증 스크립트 (비밀값 포함 가능 — 커밋 원천 차단)
/tmp-*.mjs
/tmp-*.sql
