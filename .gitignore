# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
.playwright-mcp/

# Claude Code 내부 설정 (커밋 불필요)
.claude/*
!.claude/skills/
!.claude/skills/**

# 스크린샷 (개발용)
*.png
*.jpg
*.jpeg

# public 폴더 정적 이미지는 배포에 필요하므로 예외 처리
!public/*.png
!public/*.jpg
!public/*.jpeg
!public/*.svg
!public/*.ico
package-lock.json
