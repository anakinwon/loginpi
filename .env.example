# ============================================================================
#  .env.example — 필수 환경변수 템플릿 (실제 값은 .env.local 에만 작성)
# ----------------------------------------------------------------------------
#  ⚠️ 절대 이 파일에 실제 비밀키를 넣지 마세요. (이 파일은 git에 커밋됨)
#  사용법: 이 파일을 복사해 .env.local 을 만들고 실제 값을 채워 넣으세요.
#     cp .env.example .env.local
#  .env.local 은 .gitignore 로 제외되어 커밋되지 않습니다.
# ============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PI_SANDBOX=false

# Pi 세션 HMAC 시크릿 — 생성: openssl rand -hex 32
PI_SESSION_SECRET=__YOUR_PI_SESSION_SECRET__


# Supabase — project settings > API (https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# Supabase Admin (서버 전용 — RLS 우회). 🔴 절대 클라이언트/깃 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=__YOUR_SERVICE_ROLE_KEY__

# Auth.js v5 — JWT 암호화 시크릿 (PI_SESSION_SECRET과 별개). 생성: openssl rand -base64 33
AUTH_SECRET=__YOUR_AUTH_SECRET__

# Google OAuth (Google Cloud Console에서 발급)
# Authorized redirect URI 필수 등록:
#   http://localhost:3000/api/auth/callback/google
#   https://loginpi.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_GOOGLE_CLIENT_SECRET


# Resend (이메일 발송) — https://resend.com 에서 API Key 발급 후 도메인 인증
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=onboarding@resend.dev


# AI 번역/봇 — Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY

# AI 번역 — Gemini (외부 SDK 없이 fetch로 직접 호출)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Pi Platform API Key (Pi Developer Portal) — 서버 전용
PI_API_KEY=YOUR_PI_API_KEY

# Cron 인증 시크릿 (프로덕션 필수) — 생성: openssl rand -hex 32
CRON_SECRET=__YOUR_CRON_SECRET__

# Telegram 봇 토큰 — 판매자 주문 알림 발송용. @BotFather 에서 봇 생성 후 발급.
# 미설정 시 Telegram 발송만 비활성(Outbox·앱 내 뱃지는 정상 동작).
# TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 봇 username(@ 제외) — 판매자 연동 딥링크(t.me/<username>?start=...) 생성용.
# TELEGRAM_BOT_USERNAME=cafe_pi_noti_bot
# webhook 검증 시크릿 — 생성: openssl rand -hex 16. setWebhook의 secret_token으로 등록.
# TELEGRAM_WEBHOOK_SECRET=__YOUR_TELEGRAM_WEBHOOK_SECRET__
# 운영 경보 수신 텔레그램 chat id(선택) — Bean 항등식 불일치 등 CRITICAL 알림 대상. 미설정 시 서버 로그만.
# ADMIN_TELEGRAM_CHAT_ID=__YOUR_ADMIN_CHAT_ID__

# PiVoice™ TURN 서버 (WebRTC NAT 릴레이)
# ── 운영 권장: Cloudflare Realtime TURN (무료 1TB/월) ──
# 발급: Cloudflare 대시보드 → Realtime → TURN 앱 생성 → Token ID + API Token 복사.
# 둘 다 설정 시 최우선 사용(코드가 서버에서 Cloudflare API 호출 → 단기 자격증명 발급).
# CLOUDFLARE_TURN_TOKEN_ID=your-cloudflare-turn-key-id
# CLOUDFLARE_TURN_API_TOKEN=your-cloudflare-turn-api-token
#
# ── 대안: HMAC 호환 TURN (자체 coturn use-auth-secret / Metered 관리형) ──
# TURN_HOST=turn.example.com
# TURN_SECRET=your-turn-secret-here
#
# 자격증명 TTL(초, 기본 3600). Cloudflare·HMAC 양쪽 공통 적용.
# TURN_CREDENTIAL_TTL=3600

# PiVoice™ v3.0 권한 슬롯 (방장 외 자동 연결 인원 / 멤버 최대 인원 — 미설정 시 2/4)
# VOICE_AUTO_SLOTS=2
# VOICE_MAX_MEMBER_SLOTS=4

# MPS A2U(App→User) 환불·정산 송금용 앱 지갑 private seed ('S'로 시작).
# Pi Developer Portal > 앱 > Wallet 에서 발급. 🔴 서버 전용 비밀 — 절대 클라이언트/깃 노출 금지.
# 미설정 시 취소 환불은 PENDING 장부 기록만 하고 실제 Pi 송금은 스킵(시드 설정 후 자동/관리자 재실행).
# PI_WALLET_PRIVATE_SEED=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# LBS 위치기반서비스 — Google Maps Platform (https://console.cloud.google.com)
# 서버 전용: Geocoding API, Reverse Geocoding, Places API
# GOOGLE_MAPS_API_KEY=AIza...
# 클라이언트용: Maps JavaScript API (지도 렌더링)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# 시세·각국통화 표시 노출 — Pi 등재 레드라인(A-5 가치평가 노출) 대응.
# ⭐ 기본은 런타임 tier 자동 분기(설정 불필요): 운영(prod)=숨김 / staging·dev=노출.
#    같은 빌드가 배포 환경(APP_TIER 런타임 판정)에 따라 다르게 표시되므로 환경별로 값을 박지 않는다.
#    운영(cafepi)은 APP_TIER 미설정→prod→자동 숨김. staging(loginpi)은 APP_TIER=staging→자동 노출.
# 이 변수는 강제 override(긴급용)만: 'true'=어디서나 노출 / 'false'=어디서나 숨김. 평상시 미설정 권장.
# 적용 대상: ① 헤더 Pi 시세칩  ② 상품 통화콤보 환율 숫자(통화 '선택'·Pi 직접입력은 항상 유지). docs/PRD_23_FUNC_TUNING.md §8.6
# NEXT_PUBLIC_FEATURE_PI_PRICE=




# ─── 아래는 보조 도구/CI 스크립트용 (앱 런타임과 무관) ──────────────────────

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Your Anthropic API key (https://console.anthropic.com)
#ANTHROPIC_API_KEY=

# ─── GitHub ───────────────────────────────────────────────────────────────────
# GitHub personal access token (for MCP GitHub server)
#GITHUB_TOKEN=

# ─── Optional: Docker platform override ──────────────────────────────────────
# DOCKER_PLATFORM=linux/arm64  # or linux/amd64 for Intel Macs / CI

# ─── Optional: Package manager override ──────────────────────────────────────
# CLAUDE_CODE_PACKAGE_MANAGER=npm  # npm | pnpm | yarn | bun

# --- Optional: Astraflow / UModelVerse (OpenAI-compatible) -------------------
# Global endpoint: https://api.umodelverse.ai/v1
#ASTRAFLOW_API_KEY=
# ASTRAFLOW_MODEL=gpt-4o-mini
# ASTRAFLOW_BASE_URL=https://api.umodelverse.ai/v1
# China endpoint: https://api.modelverse.cn/v1
#ASTRAFLOW_CN_API_KEY=
# ASTRAFLOW_CN_MODEL=gpt-4o-mini
# ASTRAFLOW_CN_BASE_URL=https://api.modelverse.cn/v1

# ─── ECC agent data (multi-harness isolation) ───────────────────────────────
# Memory hooks (sessions, learned skills, aliases, metrics). Default: ~/.claude
# Use a separate root when running ECC in Cursor alongside Claude Code:
# ECC_AGENT_DATA_HOME=$HOME/.cursor/ecc

# ─── Session & Security ─────────────────────────────────────────────────────
# GitHub username (used by CI scripts for credential context)
GITHUB_USER="your-github-username"

# Primary development branch for CI diff-based checks
DEFAULT_BASE_BRANCH="main"

# Path to session-start.sh (used by test/test_session_start.sh)
SESSION_SCRIPT="./session-start.sh"

# Path to generated MCP configuration file
CONFIG_FILE="./mcp-config.json"

# ─── Optional: Verbose Logging ──────────────────────────────────────────────
# Enable verbose logging for session and CI scripts
ENABLE_VERBOSE_LOGGING="false"

# ─── Optional: 운영 도구(/admin/deploy · /admin/db-switch) ───────────────────
# 미설정 시 해당 관리자 기능은 '미구성'으로 비활성(graceful). MASTER 전용 화면.
# 운영 승격(master→production fast-forward)용 GitHub 토큰 (repo contents:write)
GITHUB_DEPLOY_TOKEN=""
GITHUB_REPO="anakinwon/loginpi"
# Stage 재배포 트리거 (Vercel Deploy Hook URL — loginpi/master)
VERCEL_STAGING_DEPLOY_HOOK=""
# 운영 재배포 보조 트리거 (Vercel Deploy Hook URL — cafepi/production)
VERCEL_PROD_DEPLOY_HOOK=""
# Staging DB 스위치(STAGING_DB_TARGET 변경)용 Vercel API
VERCEL_API_TOKEN=""
VERCEL_TEAM_ID=""
VERCEL_STAGING_PROJECT_ID=""
# 운영 배포 상태 조회용 cafepi 프로젝트 ID (운영 배포 상태 표시)
VERCEL_PROD_PROJECT_ID=""
